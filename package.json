{
  "name": "mock-web",
  "version": "1.0.0",
  "description": "mock data online",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "esbuild api/dev.ts --bundle --platform=node --format=esm --packages=external --outfile=.dev/api-dev.mjs --log-level=warning && node .dev/api-dev.mjs",
    "build:api-dev": "esbuild api/dev.ts --bundle --platform=node --format=esm --packages=external --outfile=.dev/api-dev.mjs --log-level=warning",
    "build": "vite build",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ilksese/mock-web.git"
  },
  "keywords": [],
