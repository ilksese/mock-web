  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/ilksese/mock-web/issues"
  },
  "homepage": "https://github.com/ilksese/mock-web#readme",
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@solidjs/router": "^0.16.1",
    "@tailwindcss/vite": "^4.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "solid-js": "^1.9.13",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.6",
    "@types/node": "^26.0.1",
