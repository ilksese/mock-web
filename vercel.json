{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/_manage/(.*)", "dest": "/api/index" },
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/workspace/(.*)", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/api/index" }
  ]
}